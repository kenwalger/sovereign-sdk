# SOVEREIGN_NODE_SECRET must be set to a unique, high-entropy passphrase of
# your own choosing before starting the node for the first time.
#
# WARNING: copying the literal placeholder value below verbatim into a live
# environment WILL break cryptographic node identity uniqueness bounds — every
# node that uses this exact string will derive the same on-disk keypair and
# produce receipts that cannot be distinguished from one another.
#
# Copy this file to .env (which is gitignored) and replace the value:
#   cp example.env .env
#   # then edit .env and set a real secret
SOVEREIGN_NODE_SECRET="YOUR_SECRET_PASSPHRASE_HERE_DO_NOT_USE_THIS_LITERAL_VALUE"
